# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# arquivos pesados — ficam no Supabase Storage, fora do repo
/media
/public/photos
/public/videos
/Fotos e videos

# banco local (produção usa Postgres/Supabase)
payload.db
*.db
*.db-shm
*.db-wal

# zips de deploy / backups / credenciais
*.zip
*.bak
/.staycloud

# scripts de migração (uso único, contêm credenciais — fora do repo)
/scripts/export-data.ts
/scripts/rest-export.mjs
/scripts/rest-import.mjs
